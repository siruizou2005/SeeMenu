{
  "name": "seemenu",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/server",
    "apps/mobile"
  ],
  "scripts": {
    "dev:server": "npm run dev -w apps/server",
    "dev:mobile": "npm run start -w apps/mobile",
    "typecheck": "npm run typecheck -w apps/server && npm run typecheck -w apps/mobile",
    "lint": "npm run lint -w apps/server && npm run lint -w apps/mobile"
  },
  "dependencies": {
    "react-dom": "19.0.0",
    "react-native-web": "^0.20.0"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "postcss": "^8.5.10"
  }
}
